---
layout: base.njk
title: Blog
permalink: /blog/
---
<section class="blog-hero">
  <div class="container">
    <h1>Blog</h1>
    <p class="section-sub">Artigos sobre aposentadoria, previdência e tributos para brasileiros no Brasil e no exterior.</p>
  </div>
</section>

<section class="blog-list-section">
  <div class="container">
    {% if collections.posts.length %}
    <div class="blog-list">
      {% for post in collections.posts %}
      <a class="blog-card" href="{{ post.url }}">
        {% if post.data.cover %}
          <img src="{{ post.data.cover }}" alt="{{ post.data.title }}">
        {% endif %}
        <div class="blog-card-body">
          <p class="eyebrow">{{ post.data.date | readableDate }}</p>
          <h2>{{ post.data.title }}</h2>
          <p>{{ post.data.excerpt }}</p>
        </div>
      </a>
      {% endfor %}
    </div>
    {% else %}
    <p>Em breve, novos artigos por aqui.</p>
    {% endif %}
  </div>
</section>
